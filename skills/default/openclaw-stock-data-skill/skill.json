    {
      "name": "search_stock_by_condition",
      "description": "按自然语言或表达式条件搜索股票，如“pe_ttm < 20 且 turnover_rate > 3%”",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索条件表达式，支持中文/英文，AND/OR/且/或 组合"
          },
          "stock_code": {
            "type": "string",
            "description": "可选，限定在某只股票内筛选"
          },
          "date": {
            "type": "string",
            "description": "可选，日期 YYYY-MM-DD 或 MM-DD；不填则按最新快照查询"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认10，最大1000"
          },
          "sort_by": {
            "type": "string",
            "description": "排序字段，可选"
          },
          "sort_order": {
            "type": "string",
            "description": "排序方向 asc 或 desc，可选"
          }
        },
        "required": ["query"]
      }
    },
