{
  "name": "dasheng-video-director",
  "version": "0.1.0",
  "stage": "video",
  "description": "视频导演层：将口播稿、字幕、HTML文章和证据素材转成可审核的分镜、构图、模板、动效、转场与音频策略。",
  "runner": "python",
  "entry": "../../scripts/dasheng_video_director.py",
